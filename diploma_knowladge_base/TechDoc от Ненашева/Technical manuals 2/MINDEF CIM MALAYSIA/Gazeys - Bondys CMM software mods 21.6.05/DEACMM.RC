ID_DIALOG DIALOG 38, 35, 170, 91
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
CLASS "DeaCMM"
CAPTION "CMM Read/Write"
MENU ID_MENU
FONT 8, "MS Sans Serif"
{
 PUSHBUTTON "&Activate", ID_ACTIVATE, 127, 68, 36, 16, WS_GROUP | WS_TABSTOP
 LTEXT "", ID_STATUS_TEXT, 57, 42, 108, 8
 LTEXT "Open Manual/Automatic", ID_CONTROL_TEXT, 84, 12, 80, 8, WS_CHILD | WS_VISIBLE | WS_GROUP
 CONTROL "", MACHINE_BMP_CTR, "BmpControl", 0 | WS_CHILD | WS_VISIBLE, 4, 5, 46, 49
 GROUPBOX "Command Selection", 120, 4, 60, 163, 28, BS_GROUPBOX | WS_CHILD | WS_VISIBLE
 CONTROL "", -1, "static", SS_BLACKRECT | WS_CHILD | WS_VISIBLE, 55, 39, 112, 13
 GROUPBOX "Control Mode", 121, 53, 3, 114, 21, BS_GROUPBOX | WS_CHILD | WS_VISIBLE
