ID_MENU MENU
BEGIN
  POPUP "&File"
  BEGIN
	 MENUITEM "E&xit...Alt+F4", CM_EXIT
  END

  POPUP "&Service"
  BEGIN
    MENUITEM "&Reset",     CM_RESET
    MENUITEM "&Disconect", CM_DISCONNECT
  END
  POPUP "&Help", HELP
  BEGIN
    MENUITEM "&Contents",     CM_CONTENTS_HLP
    MENUITEM "&Architecture", CM_ARCHITECTURE_HLP
    MENUITEM "&Device Drivers", CM_CONTROLS_HLP
  END
END

